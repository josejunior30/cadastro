<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Teste Pluggy Connect</title>
</head>
<body>
  <h1>Teste Pluggy Connect</h1>

  <button onclick="abrirPluggy()">Conectar com Pluggy</button>

  <pre id="resultado"></pre>

  <script src="https://cdn.pluggy.ai/pluggy-connect/v2/pluggy-connect.js"></script>

  <script>
    function abrirPluggy() {
      const connectToken = prompt("Cole o accessToken retornado pelo backend");

      const pluggyConnect = new PluggyConnect({
        connectToken: connectToken,
        includeSandbox: true,
        language: "pt",
        products: ["ACCOUNTS", "TRANSACTIONS"],

        onSuccess: function (itemData) {
          console.log("Conexão criada:", itemData);

          document.getElementById("resultado").textContent =
            JSON.stringify(itemData, null, 2);

          alert("Item ID: " + itemData.item.id);
        },

        onError: function (error) {
          console.error("Erro:", error);

          document.getElementById("resultado").textContent =
            JSON.stringify(error, null, 2);
        },

        onClose: function () {
          console.log("Widget fechado");
        }
      });

      pluggyConnect.init();
    }
  </script>
</body>
</html>